{
    "name": "expire-tabs",
    "version": "1.1.1",
    "description": "A simple browser (Chrome & Firefox) that closes your tabs after some time. The time taken into account is the time since the tab was last opened / focused.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vict0rsch/expire-tabs.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/vict0rsch/expire-tabs/issues"
    },
    "homepage": "https://github.com/vict0rsch/expire-tabs#readme",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build && wxt build -b firefox",
        "zip": "wxt zip && wxt zip -b firefox",
        "postinstall": "wxt prepare",
        "pretest": "bun run build",
        "test": "mocha test/**/*.mjs",
        "pretest:firefox": "bun run build",
        "test:firefox": "browser=firefox mocha test/**/*.mjs",
        "pretest:both": "bun run build",
        "test:both": "concurrently 'bunx mocha test/**/*.mjs' 'browser=firefox bunx mocha test/**/*.mjs'",
        "pretest:glob": "bun run build",
        "test:glob": "bunx mocha",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@prefresh/core": "^1.5.9",
        "@prefresh/utils": "^1.2.1",
        "chai": "^6.2.1",
        "concurrently": "^9.2.1",
        "mocha": "^11.7.5",
        "preact": "^10.27.2",
        "prettier": "^3.8.3",
        "puppeteer": "^24.31.0",
        "sinon": "^21.0.0",
        "wxt": "^0.20.25"
    },
    "dependencies": {
        "luxon": "^3.7.2"
    }
}
